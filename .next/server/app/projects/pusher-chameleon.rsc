c:{"metadata":[["$","title","0",{"children":"Pusher Chameleon"}],["$","meta","1",{"name":"description","content":"How to share front-end assets across projects"}],["$","meta","2",{"name":"creator","content":"Saurabh Sharma"}],["$","meta","3",{"name":"publisher","content":"Saurabh Sharma"}],["$","meta","4",{"property":"og:title","content":"Saurabh Sharma - Sr. Developer"}],["$","meta","5",{"property":"og:description","content":"Saurabh Sharma is a software developer based in India, working somewhere on the boundary between design and code."}],["$","meta","6",{"property":"og:site_name","content":"Saurabh Sharma - Sr. Developer"}],["$","meta","7",{"property":"og:image","content":"https://saurabhcoded.com/og.png"}],["$","meta","8",{"property":"og:image:width","content":"1200"}],["$","meta","9",{"property":"og:image:height","content":"630"}],["$","meta","10",{"property":"og:image:alt","content":"Saurabh Sharma - Sr. Developer"}],["$","meta","11",{"property":"og:type","content":"website"}],["$","meta","12",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","13",{"name":"twitter:creator","content":"@saurabhcoded"}],["$","meta","14",{"name":"twitter:title","content":"Saurabh Sharma - Sr. Developer"}],["$","meta","15",{"name":"twitter:description","content":"Saurabh Sharma is a software developer based in India, working somewhere on the boundary between design and code."}],["$","meta","16",{"name":"twitter:image","content":"https://saurabhcoded.com/og.png"}],["$","link","17",{"rel":"icon","href":"/favicon.ico","type":"image/x-icon","sizes":"16x16"}],["$","$L24","18",{}]],"error":null,"digest":"$undefined"}
