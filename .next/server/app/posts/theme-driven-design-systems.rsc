17:["$","p",null,{"children":"Abstracting the style values out from the individual implementations, allows us to have a single source of truth and keep our code dryer."}]
18:["$","h2",null,{"children":"Sharing values across platforms"}]
19:["$","p",null,{"children":"To further complicate the above example, consider if the second component was not written in HTML, but rather was a React component written using emotion/styled-components which might look something like this:"}]
