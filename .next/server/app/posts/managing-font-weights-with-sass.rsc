8:[["$","main",null,{"className":"px-4 md:px-0","children":[["$","section",null,{"children":[["$","h1",null,{"className":"font-semibold tracking-tight text-4xl text-slate-900","children":"Managing font weights with Sass"}],["$","span",null,{"className":"text-slate-500 text-sm tracking-tight font-mono block mt-4","children":["Published on"," ",["$","time",null,{"dateTime":"2016-04-12","children":"12 Apr 2016"}]]}]]}],["$","section",null,{"className":"py-5","children":["$","article",null,{"className":"prose prose-lg","children":"$L13"}]}]]}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BlogPosting\",\"headline\":\"Managing font weights with Sass\",\"url\":\"https://saurabhcoded.github.io/posts/managing-font-weights-with-sass\",\"datePublished\":\"2016-04-12\",\"dateModified\":\"2016-04-12\",\"author\":[{\"@type\":\"Person\",\"name\":\"Saurabh Sharma\",\"url\":\"https://saurabhcoded.github.io\"}]}"}}]]
13:[["$","p",null,{"children":"Managing font families and weights shouldn't be a big deal. Add the font family to the body tag, and define the font weights on the individual titles."}],"\n",["$","p",null,{"children":["However, when dealing with some web font providers (looking at you fonts.com!), you might find that different font weights require entirely seperate font families. For example the DIN Next family is provided as two fonts. One for the ",["$","code",null,{"children":"light"}],", ",["$","code",null,{"children":"medium"}],", and ",["$","code",null,{"children":"bold"}]," weights, and another for the ",["$","code",null,{"children":"regular"}]," weight."]}],"\n",["$","h2",null,{"children":"How to work with this"}],"\n",["$","p",null,{"children":"The way that we solved this at Pusher, is to use Sass's placeholder classes. These allow us to define multiple CSS properties with just one line. Think of them as multiline variables."}],"\n",["$","h3",null,{"children":"The Old Way"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"hljs language-scss","children":[["$","span",null,{"className":"hljs-variable","children":"$$font-family-primary"}],": ",["$","span",null,{"className":"hljs-string","children":"'Open Sans'"}],", sans-serif;\n\n",["$","span",null,{"className":"hljs-selector-tag","children":"body"}]," {\n  ",["$","span",null,{"className":"hljs-attribute","children":"font-family"}],": ",["$","span",null,{"className":"hljs-variable","children":"$$font-family-primary"}],";\n}\n\n",["$","span",null,{"className":"hljs-selector-tag","children":"h1"}]," {\n  ",["$","span",null,{"className":"hljs-attribute","children":"font-weight"}],": bold;\n}\n"]}]}],"\n",["$","h3",null,{"children":"The Improved way"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"hljs language-scss","children":["%",["$","span",null,{"className":"hljs-attribute","children":"font-weight"}],"-regular {\n  ",["$","span",null,{"className":"hljs-attribute","children":"font-family"}],": ",["$","span",null,{"className":"hljs-string","children":"'Open Sans WF Regular'"}],", sans-serif;\n  ",["$","span",null,{"className":"hljs-attribute","children":"font-weight"}],": regular;\n}\n\n%",["$","span",null,{"className":"hljs-attribute","children":"font-weight"}],"-bold {\n  ",["$","span",null,{"className":"hljs-attribute","children":"font-family"}],": ",["$","span",null,{"className":"hljs-string","children":"'Open Sans WF Bold'"}],", sans-serif;\n  ",["$","span",null,{"className":"hljs-attribute","children":"font-weight"}],": bold;\n}\n\n",["$","span",null,{"className":"hljs-selector-tag","children":"body"}]," {\n  ",["$","span",null,{"className":"hljs-keyword","children":"@extend"}]," %font-weight-regular;\n}\n\n",["$","span",null,{"className":"hljs-selector-tag","children":"h1"}]," {\n  ",["$","span",null,{"className":"hljs-keyword","children":"@extend"}]," %font-weight-bold;\n}\n\n",["$","span",null,{"className":"hljs-selector-class","children":".nav__logo"}]," {\n  ",["$","span",null,{"className":"hljs-keyword","children":"@extend"}]," %font-weight-bold;\n}\n"]}]}],"\n",["$","p",null,{"children":["The added benefit of this, is that any selector that is extended by the ",["$","code",null,{"children":"%font-weight-XXX"}]," classes will be grouped, helping to reduce duplication in your compiled CSS:"]}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"hljs language-css","children":[["$","span",null,{"className":"hljs-selector-tag","children":"body"}]," {\n  ",["$","span",null,{"className":"hljs-attribute","children":"font-family"}],": ",["$","span",null,{"className":"hljs-string","children":"'Open Sans WF Regular'"}],", sans-serif;\n  ",["$","span",null,{"className":"hljs-attribute","children":"font-weight"}],": regular;\n}\n\n",["$","span",null,{"className":"hljs-selector-tag","children":"h1"}],",\n",["$","span",null,{"className":"hljs-selector-class","children":".nav__logo"}]," {\n  ",["$","span",null,{"className":"hljs-attribute","children":"font-family"}],": ",["$","span",null,{"className":"hljs-string","children":"'Open Sans WF Bold'"}],", sans-serif;\n  ",["$","span",null,{"className":"hljs-attribute","children":"font-weight"}],": bold;\n}\n"]}]}]]
