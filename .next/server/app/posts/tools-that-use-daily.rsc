8:[["$","main",null,{"className":"px-4 md:px-0","children":[["$","section",null,{"children":[["$","h1",null,{"className":"font-semibold tracking-tight text-4xl text-slate-900","children":"Tools that I use on a daily basis"}],["$","span",null,{"className":"text-slate-500 text-sm tracking-tight font-mono block mt-4","children":["Published on"," ",["$","time",null,{"dateTime":"2015-02-10","children":"10 Feb 2015"}]]}]]}],["$","section",null,{"className":"py-5","children":["$","article",null,{"className":"prose prose-lg","children":"$L13"}]}]]}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BlogPosting\",\"headline\":\"Tools that I use on a daily basis\",\"url\":\"https://saurabhcoded.github.io/posts/tools-that-use-daily\",\"datePublished\":\"2015-02-10\",\"dateModified\":\"2015-02-10\",\"author\":[{\"@type\":\"Person\",\"name\":\"Saurabh Sharma\",\"url\":\"https://saurabhcoded.github.io\"}]}"}}]]
13:[["$","p",null,{"children":"I always find it interesting to see what tools and techniques other developers use in their workflow. Of course these are often dictated by the team, and scoped to the project. None the less, here's a quick rundown of design/development tools that I use day to day."}],"\n",["$","h2",null,{"children":"Design - Sketch"}],"\n",["$","p",null,{"children":"I've been using Sketch on and off for projects for the past couple of months. However, since starting at Rareloop as a part-time developer, it's become the go-to design tool. Although I still use Photoshop every now and then for more advanced graphic/photo manipulation."}],"\n",["$","h2",null,{"children":"Text Editor - Sublime Text 3"}],"\n",["$","p",null,{"children":"Nuff said."}],"\n",["$","h2",null,{"children":"Task Runner - Grunt"}],"\n",["$","p",null,{"children":"Grunt manages all of my front-end tasks, from compiling Sass to optimizing images. I should note though, that I recently dropped Grunt from the workflow for this site, due there simply not being the need for it. Instead I switched over to ruby based tools (Jekyll Assets, autoprefixer-rails)."}],"\n",["$","h2",null,{"children":"Database Management - Sequel Pro"}],"\n",["$","p",null,{"children":"I mainly use Sequel Pro to play with databases that have already been implemented. I still opt for the migration workflow if I'm developing with Laravel."}],"\n",["$","hr",null,{}],"\n",["$","p",null,{"children":["$","em",null,{"children":"With new tools and techniques coming out daily, my workflow is always changing, so this is in no way a definitive list."}]}]]
