8:[["$","main",null,{"className":"px-4 md:px-0","children":[["$","section",null,{"children":[["$","h1",null,{"className":"font-semibold tracking-tight text-4xl text-slate-900","children":"Future CSS: Native scroll animations"}],["$","span",null,{"className":"text-slate-500 text-sm tracking-tight font-mono block mt-4","children":["Published on"," ",["$","time",null,{"dateTime":"2024-05-20","children":"20 May 2024"}]]}]]}],["$","section",null,{"className":"py-5","children":["$","article",null,{"className":"prose prose-lg","children":"$L13"}]}]]}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BlogPosting\",\"headline\":\"Future CSS: Native scroll animations\",\"url\":\"https://saurabhcoded.github.io/posts/future-css-scroll-animations\",\"datePublished\":\"2024-05-20\",\"dateModified\":\"2024-05-20\",\"author\":[{\"@type\":\"Person\",\"name\":\"Saurabh Sharma\",\"url\":\"https://saurabhcoded.github.io\"}]}"}}]]
