13:[["$","p",null,{"children":"Progress circles are a classic dashboard element. They provide stats in a quick to digest view. There are several ways to go about implementing one. You can either use javascript and render it in canvas, hack it together in CSS, use an image, or use SVG's."}],"\n",["$","h2",null,{"children":["$","a",null,{"href":"http://codepen.io/alexpate/pen/NNBEoq","children":"View The Demo"}]}],"\n",["$","p",null,{"children":"Making a progress circle in SVG isn't as hard as you might imagine. Let's start with the basics:"}],"\n",["$","h2",null,{"children":"1 - Create the backdrop circle"}],"\n",["$","p",null,{"children":["Here, we create a basic shape that's got a radius of 90px. The ",["$","code",null,{"children":"cx"}]," and ",["$","code",null,{"children":"cy"}]," values allow us to center the circle inside the SVG element. These are the points at which we want the center of the circle to be (so half of the width/height of the SVG element)."]}],"\n",["$","p",null,{"children":"We've also added a few stylistic properties such as giving it a 3px grey stroke."}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"hljs language-html","children":[["$","span",null,{"className":"hljs-tag","children":["<",["$","span",null,{"className":"hljs-name","children":"svg"}]," ",["$","span",null,{"className":"hljs-attr","children":"width"}],"=",["$","span",null,{"className":"hljs-string","children":"\"240\""}]," ",["$","span",null,{"className":"hljs-attr","children":"height"}],"=",["$","span",null,{"className":"hljs-string","children":"\"240\""}]," ",["$","span",null,{"className":"hljs-attr","children":"xmlns"}],"=",["$","span",null,{"className":"hljs-string","children":"\"http://www.w3.org/2000/svg\""}],">"]}],"\n  ",["$","span",null,{"className":"hljs-tag","children":["<",["$","span",null,{"className":"hljs-name","children":"circle"}]," ",["$","span",null,{"className":"hljs-attr","children":"r"}],"=",["$","span",null,{"className":"hljs-string","children":"\"90\""}]," ",["$","span",null,{"className":"hljs-attr","children":"cy"}],"=",["$","span",null,{"className":"hljs-string","children":"\"120\""}]," ",["$","span",null,{"className":"hljs-attr","children":"cx"}],"=",["$","span",null,{"className":"hljs-string","children":"\"120\""}]," ",["$","span",null,{"className":"hljs-attr","children":"stroke-width"}],"=",["$","span",null,{"className":"hljs-string","children":"\"3\""}]," ",["$","span",null,{"className":"hljs-attr","children":"stroke"}],"=",["$","span",null,{"className":"hljs-string","children":"\"#333\""}]," ",["$","span",null,{"className":"hljs-attr","children":"fill"}],"=",["$","span",null,{"className":"hljs-string","children":"\"none\""}]," />"]}],"\n",["$","span",null,{"className":"hljs-tag","children":["</",["$","span",null,{"className":"hljs-name","children":"svg"}],">"]}],"\n"]}]}],"\n",["$","p",null,{"children":["$","img",null,{"src":"/posts/2016-04-12-pure-svg-progress-circles/svg_progress_circle_one.png","alt":"SVG progress circle base"}]}],"\n",["$","h2",null,{"children":"2 - Add the progress circle"}],"\n",["$","p",null,{"children":"The circle that we just created will act as a backdrop to our actual progress circle. Let's make that now:"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"hljs language-html","children":[["$","span",null,{"className":"hljs-tag","children":["<",["$","span",null,{"className":"hljs-name","children":"svg"}]," ",["$","span",null,{"className":"hljs-attr","children":"width"}],"=",["$","span",null,{"className":"hljs-string","children":"\"240\""}]," ",["$","span",null,{"className":"hljs-attr","children":"height"}],"=",["$","span",null,{"className":"hljs-string","children":"\"240\""}]," ",["$","span",null,{"className":"hljs-attr","children":"xmlns"}],"=",["$","span",null,{"className":"hljs-string","children":"\"http://www.w3.org/2000/svg\""}],">"]}],"\n  ",["$","span",null,{"className":"hljs-tag","children":["<",["$","span",null,{"className":"hljs-name","childre