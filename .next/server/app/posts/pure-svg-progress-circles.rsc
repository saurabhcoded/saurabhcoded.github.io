22:["$","pre",null,{"children":["$","code",null,{"className":"hljs language-css","children":[["$","span",null,{"className":"hljs-selector-id","children":"#progress"}]," {\n  stroke-dasharray: ",["$","span",null,{"className":"hljs-number","children":"100px"}],";\n  stroke-dashoffset: ",["$","span",null,{"className":"hljs-number","children":"100px"}],";\n  ",["$","span",null,{"className":"hljs-attribute","children":"animation"}],": progressAnimation ",["$","span",null,{"className":"hljs-number","children":"600ms"}]," linear infinite;\n}\n\n",["$","span",null,{"className":"hljs-keyword","children":"@keyframes"}]," progressAnimation {\n  ",["$","span",null,{"className":"hljs-selector-tag","children":"from"}]," {\n    stroke-dashoffset: ",["$","span",null,{"className":"hljs-number","children":"100px"}],";\n  }\n  ",["$","span",null,{"className":"hljs-selector-tag","children":"to"}]," {\n    stroke-dashoffset: ",["$","span",null,{"className":"hljs-number","children":"300px"}],";\n  }\n}\n"]}]}]
