1f:["$","pre",null,{"children":["$","code",null,{"className":"hljs language-css","children":[["$","span",null,{"className":"hljs-comment","children":"/* Designate the container */"}],"\n",["$","span",null,{"className":"hljs-selector-class","children":".card-container"}]," {\n  container-type: inline-size;\n}\n\n",["$","span",null,{"className":"hljs-comment","children":"/* Default card styles */"}],"\n",["$","span",null,{"className":"hljs-selector-class","children":".card"}]," {\n  ",["$","span",null,{"className":"hljs-attribute","children":"display"}],": flex;\n  ",["$","span",null,{"className":"hljs-attribute","children":"flex-direction"}],": column;\n}\n\n",["$","span",null,{"className":"hljs-comment","children":"/* Adjust card layout based on container width */"}],"\n",["$","span",null,{"className":"hljs-keyword","children":"@container"}]," (",["$","span",null,{"className":"hljs-attribute","children":"min-width"}],": ",["$","span",null,{"className":"hljs-number","children":"500px"}],") {\n  ",["$","span",null,{"className":"hljs-selector-class","children":".card"}]," {\n    ",["$","span",null,{"className":"hljs-attribute","children":"flex-direction"}],": row;\n    ",["$","span",null,{"className":"hljs-attribute","children":"align-items"}],": center;\n  }\n}\n"]}]}]
20:["$","p",null,{"children":["$","em",null,{"children":"Note: We've removed some of the styles for the card to only show the container query CSS in action!"}]}]
21:["$","p",null,{"children":["In this setup, the ",["$","code",null,{"children":".card"}]," will stack its content vertically by default. However, when its parent ",["$","code",null,{"children":".card-container"}]," is at least 500 pixels wide, the ",["$","code",null,{"children":".card"}]," switches to a horizontal layout."]}]
22:["$","h3",null,{"children":"When to Use Container Queries"}]
23:["$","p",null,{"children":"Container Queries are ideal for:"}]
24:["$","ul",null,{"children":["\n",["$","li",null,{"children":[["$","strong",null,{"children":"Reusable Components"}],": Create elements that adapt seamlessly in different parts of your site without additional tweaks."]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"Nested Layouts"}],": Design components that respond intelligently when placed inside grids, flex containers, or other complex layouts."]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"Design Systems"}],": Develop a consistent and flexible UI library where components are truly modular."]}],"\n"]}]
25:["$","h3",null,{"children":"Comparing Media Queries and Container Queries"}]
26:["$","p",null,{"children":["$","strong",null,{"children":"Using Media Queries"}]}]
27:["$","pre",null,{"children":["$","code",null,{"className":"hljs language-css","children":[["$","span",null,{"className":"hljs-keyword","children":"@media"}]," (",["$","span",null,{"className":"hljs-attribute","children":"min-width"}],": ",["$","span",null,{"className":"hljs-number","children":"800px"}],") {\n  ",["$","span",null,{"className":"hljs-selector-class","children":".sidebar"}]," {\n    ",["$","span",null,{"className":"hljs-attribute","children":"width"}],": ",["$","span",null,{"className":"hljs-number","children":"250px"}],";\n  }\n}\n"]}]}]
28:["$","p",null,{"children":["This adjusts the ",["$","code",null,{"children":".sidebar"}]," based on the viewport width, which might not be ideal if the sidebar is within a narrower container."]}]
