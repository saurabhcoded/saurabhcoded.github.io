2a:["$","pre",null,{"children":["$","code",null,{"className":"hljs language-css","children":[["$","span",null,{"className":"hljs-selector-class","children":".sidebar-container"}]," {\n  container-type: inline-size;\n}\n\n",["$","span",null,{"className":"hljs-keyword","children":"@container"}]," (",["$","span",null,{"className":"hljs-attribute","children":"min-width"}],": ",["$","span",null,{"className":"hljs-number","children":"500px"}],") {\n  ",["$","span",null,{"className":"hljs-selector-class","children":".sidebar"}]," {\n    ",["$","span",null,{"className":"hljs-attribute","children":"width"}],": ",["$","span",null,{"className":"hljs-number","children":"250px"}],";\n  }\n}\n"]}]}]
2b:["$","p",null,{"children":["Here, the ",["$","code",null,{"children":".sidebar"}]," adjusts its width based on the size of ",["$","code",null,{"children":".sidebar-container"}],", making it more adaptable to different layouts."]}]
2c:["$","h3",null,{"children":"Gotchas to Keep in Mind"}]
2d:["$","p",null,{"children":"Before you start sprinkling container queries all over your stylesheet, here are a few things to consider:"}]
2e:["$","p",null,{"children":["$","strong",null,{"children":"Browser Support"}]}]
2f:["$","p",null,{"children":["As of September 2024, container queries are supported in the latest versions of Chrome, Edge, Firefox, and Safari. Firefox has partial support, but you might need to enable it manually in the settings. It's worth checking ",["$","a",null,{"href":"https://caniuse.com/css-container-queries","children":"Can I Use"}]," before deploying to production to ensure your target browsers are supported."]}]
30:["$","p",null,{"children":["$","strong",null,{"children":"Performance Considerations"}]}]
31:["$","p",null,{"children":"While container queries are powerful, they can introduce performance overhead if overused or applied to very deep or complex DOM trees. It's a good idea to use them thoughtfully and test their impact on your site's performance."}]
32:["$","h3",null,{"children":"Conclusion"}]
33:["$","p",null,{"children":"CSS Container Queries open up a whole new world for responsive design, allowing components to be truly context-aware. They help eliminate the need for excessive media queries and make your codebase cleaner and more maintainable."}]
34:["$","p",null,{"children":"If you're interested in learning more, here are some resources:"}]
35:["$","ul",null,{"children":["\n",["$","li",null,{"children":["$","a",null,{"href":"https://developer.mozilla.org/en-US/docs/Web/CSS/CSS_Container_Queries","children":"MDN: CSS Container Queries"}]}],"\n",["$","li",null,{"children":["$","a",null,{"href":"https://caniuse.com/css-container-queries","children":"Can I Use: CSS Container Queries"}]}],"\n"]}]
