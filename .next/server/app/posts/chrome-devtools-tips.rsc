8:[["$","main",null,{"className":"px-4 md:px-0","children":[["$","section",null,{"children":[["$","h1",null,{"className":"font-semibold tracking-tight text-4xl text-slate-900","children":"Things you might not have known you could do in Chrome DevTools"}],["$","span",null,{"className":"text-slate-500 text-sm tracking-tight font-mono block mt-4","children":["Published on"," ",["$","time",null,{"dateTime":"2021-08-24","children":"24 Aug 2021"}]]}]]}],["$","section",null,{"className":"py-5","children":["$","article",null,{"className":"prose prose-lg","children":"$L13"}]}]]}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BlogPosting\",\"headline\":\"Things you might not have known you could do in Chrome DevTools\",\"url\":\"https://saurabhcoded.github.io/posts/chrome-devtools-tips\",\"datePublished\":\"2021-08-24\",\"dateModified\":\"2021-08-24\",\"author\":[{\"@type\":\"Person\",\"name\":\"Saurabh Sharma\",\"url\":\"https://saurabhcoded.github.io\"}]}"}}]]
13:[["$","p",null,{"children":"DevTools are an invaluable part of an web engineers toolkit. Here's a few things that you might not have known."}],"\n",["$","h2",null,{"children":"1) Full page screenshots"}],"\n",["$","p",null,{"children":"You can capture a screenshot of a specific node. Just select the element, hit 'cmd+shift+p', and type 'capture node screenshot'"}],"\n",["$","video",null,{"controls":true,"autoPlay":true,"loop":true,"muted":true,"children":["$","source",null,{"src":"/posts/2021-08-24-chrome-devtools-tips/screenshots.mp4","type":"video/mp4"}]}],"\n",["$","h2",null,{"children":"2) jQuery style variables"}],"\n",["$","p",null,{"children":"Just can't let go of jQuery? When selecting elements in the console, use $ as an alias for document.querySelector"}],"\n",["$","p",null,{"children":["$","img",null,{"src":"/posts/2021-08-24-chrome-devtools-tips/jquery-variables.png","alt":""}]}],"\n",["$","h2",null,{"children":"3) console.table"}],"\n",["$","p",null,{"children":"Want to log an array of data? Use console.table() and your array will be rendered in to a table"}],"\n",["$","p",null,{"children":["$","img",null,{"src":"/posts/2021-08-24-chrome-devtools-tips/console-table.jpeg","alt":""}]}],"\n",["$","h2",null,{"children":"4) CSS shortcuts"}],"\n",["$","p",null,{"children":"Trying to work out where an element is inheriting a particular style from? Use the 'computed' style tab to view the properties that are rendered along with a link to what selector is adding that property."}],"\n",["$","video",null,{"controls":true,"autoPlay":true,"loop":true,"muted":true,"children":["$","source",null,{"src":"/img/2021-08-24-chrome-devtools-tips/style-inheritance.mp4","type":"video/mp4"}]}],"\n",["$","h2",null,{"children":"5) What the font"}],"\n",["$","p",null,{"children":"You can also view the font that is rendered in the computed style tab, along with whether it's a local or network font."}],"\n",["$","p",null,{"children":["$","img",null,{"src":"/posts/2021-08-24-chrome-devtools-tips/font-rendering.png","alt":""}]}],"\n",["$","h2",null,{"children":"6) Debugging network requests"}],"\n",["$","p",null,{"children":"Trying to debug a network request? Right-clicking the request in the Network tab will allow you to copy the request in a range of pre-formatted requests."}],"\n",["$","p",null,{"children":["$","img",null,{"src":"/posts/2021-08-24-chrome-devtools-tips/debug-network.jpeg","alt":""}]}],"\n",["$","h2",null,{"children":"7) Image as a data URI"}],"\n",["$","p",null,{"children":"Select an image in the Application tab to quickly get it as a data URI"}],"\n",["$","p",null,{"children":["$","img",null,{"src":"/posts/2021-08-24-chrome-devtools-tips/image-data-uri.jpeg","alt":""}]}],"\n",["$","p",null,{"children":["$","em",null,{"children":["These tips were originally posted in ",["$","a",null,{"href":"https://twitter.com/alexjpate/status/1270722106662125568","children":"this thread on Twitter"}]]}]}]]
