8:[["$","main",null,{"className":"px-4 md:px-0","children":[["$","section",null,{"children":[["$","h1",null,{"className":"font-semibold tracking-tight text-4xl text-slate-900","children":"How to name Sass color variables"}],["$","span",null,{"className":"text-slate-500 text-sm tracking-tight font-mono block mt-4","children":["Published on"," ",["$","time",null,{"dateTime":"2016-09-05","children":"5 Sept 2016"}]]}]]}],["$","section",null,{"className":"py-5","children":["$","article",null,{"className":"prose prose-lg","children":"$L13"}]}]]}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BlogPosting\",\"headline\":\"How to name Sass color variables\",\"url\":\"https://saurabhcoded.github.io/posts/naming-sass-color-variables\",\"datePublished\":\"2016-09-05\",\"dateModified\":\"2016-09-05\",\"author\":[{\"@type\":\"Person\",\"name\":\"Saurabh Sharma\",\"url\":\"https://saurabhcoded.github.io\"}]}"}}]]
13:[["$","p",null,{"children":"When it comes to naming Sass variables, I suck. I think I've found the perfect solution, get half way through a project, and realise what a terrible mistake I'd made."}],"\n",["$","p",null,{"children":"Variables in any language are often overlooked. They're treated as these things that 'ultimately only developers will see, so who cares'. But having a proper naming convention can really help save time, keep your code DRY, and more importantly make your codebase easier to understand for other developers."}],"\n",["$","h2",null,{"children":"The Bad"}],"\n",["$","p",null,{"children":"So let's start with the bad. Going back a few months, this is pretty much what the variables file in all of my old projects looked like:"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"hljs language-scss","children":[["$","span",null,{"className":"hljs-variable","children":"$$red"}],": ",["$","span",null,{"className":"hljs-number","children":"#e03c31"}],";\n",["$","span",null,{"className":"hljs-variable","children":"$$darker-red"}],": ",["$","span",null,{"className":"hljs-number","children":"#c1271d"}],";\n",["$","span",null,{"className":"hljs-variable","children":"$$blue"}],": ",["$","span",null,{"className":"hljs-number","children":"#00f"}],";\n",["$","span",null,{"className":"hljs-variable","children":"$$text-color"}],": ",["$","span",null,{"className":"hljs-number","children":"#1a1a1a"}],";\n"]}]}],"\n",["$","p",null,{"children":"What's the problem here?"}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"The variable names provide no clues as to where they sit in the hierarchy, or their relationship with one another."}],"\n",["$","li",null,{"children":"What's the primary color? Red? Blue?"}],"\n",["$","li",null,{"children":["What happens if our color scheme changes? We suddenly have to change every instance of ",["$","code",null,{"children":"$$red"}],", with our new color. These defeats the point of having variables in the first place."]}],"\n",["$","li",null,{"children":[["$","em",null,{"children":"'Darker Red'"}],"? How much darker is darker?"]}],"\n"]}],"\n",["$","h2",null,{"children":"Better"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"hljs language-scss","children":[["$","span",null,{"className":"hljs-variable","children":"$$primary-color"}],": ",["$","span",null,{"className":"hljs-number","children":"#e03c31"}],";\n",["$","span",null,{"className":"hljs-variable","children":"$$secondary-color"}],": ",["$","span",null,{"className":"hljs-number","children":"#7fff00"}],";\n",["$","span",null,{"className":"hljs-variable","children":"$$text-color"}],": ",["$","span",null,{"className":"hljs-number","children":"#1a1a1a"}],";\n"]}]}],"\n",["$","p",null,{"children":["Now we've provided some context, we can better see the relationship between our colors. We have a ",["$","code",null,{"children":"$$primary-color"}]," and ",["$","code",null,{"children":"$$secondary-color"}],", which would be our brand colors, and then provide some other utility variables such as ",["$","code",null,{"children":"$$text-color"}],"."]}],"\n",["$","h2",null,{"children":"Even Better"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"hljs language-scss","children":[["$","span",null,{"className":"hljs-comment","children":"// Internal variables"}],"\n",["$","span",null,{"className":"hljs-variable","children":"$$x-palette-red"}],": ",["$","span",null,{"className":"hljs-number","children":"#e03c31"}],";\n",["$","span",null,{"className":"hljs-variable","children":"$$x-palette-green"}],": ",["$","span",null,{"className":"hljs-number","children":"#7fff00"}],";\n\n",["$","span",null,{"className":"hljs-comment","children":"// Global variables"}],"\n",["$","span",null,{"className":"hljs-variable","children":"$$palette-primary"}],": ",["$","span",null,{"className":"hljs-variable","children":"$$x-color-red"}],";\n",["$","span",null,{"className":"hljs-variable","children":"$$palette-secondary"}],": ",["$","span",null,{"className":"hljs-variable","children":"$$x-color-green"}],";\n\n",["$","span",null,{"className":"hljs-variable","children":"$$palette-paragraph"}],": ",["$","span",null,{"className":"hljs-number","children":"#1a1a1a"}],";\n"]}]}],"\n",["$","p",null,{"children":"This is a method that I've recently started using in all of my new projects."}],"\n","$L14","\n","$L15","\n","$L16","\n","$L17"]
14:["$","p",null,{"children":["First we define our colors at a very high level using internal variables. I like to prefix my internal variables with ",["$","code",null,{"children":"x"}],". Internal variables have one function, and that's to be assigned to other variables. This allows us to keep our global variables free of any bias, but also informs us and others working on the codebase what the actual palette color is. Because let's face it, hex codes are for machines."]}]
15:["$","p",null,{"children":"We've also switched around the naming of the actual color variables, to follow a 'property -> level' convention. This is particulary useful when these are surrounded by other variables for typography, grids, etc., as we can instantly scan our variables file by property."}]
16:["$","pre",null,{"children":["$","code",null,{"className":"hljs language-scss","children":[["$","span",null,{"className":"hljs-variable","children":"$$palette-primary"}],": ",["$","span",null,{"className":"hljs-variable","children":"$$x-color-red"}],";\n",["$","span",null,{"className":"hljs-variable","children":"$$palette-secondary"}],": ",["$","span",null,{"className":"hljs-variable","children":"$$x-color-blue"}],";\n",["$","span",null,{"className":"hljs-variable","children":"$$palette-tertiary"}],": ",["$","span",null,{"className":"hljs-variable","children":"$$x-color-green"}],";\n\n",["$","span",null,{"className":"hljs-variable","children":"$$font-family-primary"}],": ",["$","span",null,{"className":"hljs-string","children":"'Helvetica Neue'"}],", sans-serif;\n",["$","span",null,{"className":"hljs-variable","children":"$$font-family-secondary"}],": ",["$","span",null,{"className":"hljs-string","children":"'Georgia'"}],", serif;\n\n",["$","span",null,{"className":"hljs-variable","children":"$$line-height-base"}],": ",["$","span",null,{"className":"hljs-number","children":"18px"}],";\n",["$","span",null,{"className":"hljs-variable","children":"$$line-height-paragraph"}],": ",["$","span",null,{"className":"hljs-number","children":"16px"}],";\n"]}]}]
17:["$","p",null,{"children":"Likewise, we use the word 'palette' to distinguish our variables from the 'color' css property which is exclusively for text color."}]
