ren":"someFunction"}],"();\n    ",["$","span",null,{"className":"hljs-keyword","children":"const"}]," anotherResult = ",["$","span",null,{"className":"hljs-keyword","children":"await"}]," ",["$","span",null,{"className":"hljs-title function_","children":"anotherFunction"}],"(result);\n    ",["$","span",null,{"className":"hljs-keyword","children":"const"}]," finalResult = ","$L14"," ","$L15","(anotherResult);\n    ","$L16"," finalResult;\n  } ","$L17"," (err) {\n    ","$L18",".","$L19","(err);\n  }\n}\n"]}]}],"\n","$L1a","\n","$L1b","\n","$L1c","\n","$L1d","\n","$L1e","\n","$L1f","\n","$L20","\n","$L21","\n","$L22","\n","$L23","\n","$L24","\n","$L25","\n","$L26"]
